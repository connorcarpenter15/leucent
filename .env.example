# =====================================================================
# Leucent root environment template.
# Copy to `.env` and/or `.env.local` in this repo root and fill in values.
#
# Monorepo dev: `pnpm dev` runs `scripts/dev.mjs`, which loads `./.env` and
# `./.env.local` (override) before Turbo starts. Every workspace package
# (apps/web, realtime-server, Python services, etc.) inherits those vars.
#
# Next.js also auto-loads `apps/web/.env*` on its own — use that only if you
# need overrides specific to the web app; you do not need to duplicate the root
# file there for normal local work.
# =====================================================================

# --- Postgres: use a Neon *development branch* for local work ---
# In the Neon Console: create a branch (e.g. `dev`) from `main`, open
# Connection details, and copy the *pooled* connection string (PgBouncer) so
# serverless / many short-lived clients behave well. Example shape:
#   postgresql://neondb_owner:****@ep-xxxxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# Enable Neon Auth on this branch before running app migrations (see DEPLOY.md).
#
# Optional: run `pnpm compose:up:local-pg` if you truly need Docker Postgres +
# pgvector on localhost instead (not the default local-dev path).
DATABASE_URL=postgres://neondb_owner:YOUR_PASSWORD@ep-REPLACE-pooler.us-east-1.aws.neon.tech:5432/neondb?sslmode=require&channel_binding=require

# --- Neon Auth (Beta) ---
# Enable Auth on the Neon branch (Neon Console -> Auth), then copy the base URL
# from Auth -> Configuration. It looks like:
#   https://ep-xxx.neonauth.<region>.aws.neon.tech/neondb/auth
NEON_AUTH_BASE_URL=https://ep-replace-me.neonauth.us-east-1.aws.neon.tech/neondb/auth
# Signing secret for the session-cache cookie. MUST be at least 32 chars.
# Generate with: openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET=replace-me-with-a-32-byte-base64-secret

# --- Realtime server ---
REALTIME_SERVER_URL=http://localhost:4000
# Browser-facing (ws://) URL for Yjs + telemetry.
NEXT_PUBLIC_REALTIME_WS_URL=ws://localhost:4000
# Shared secret used by web/AI/sandbox to call realtime /internal/* routes.
REALTIME_INTERNAL_TOKEN=local-dev-internal-token-change-me
# JWT signing secret (must match between web app and realtime server).
REALTIME_JWT_SECRET=local-dev-jwt-secret-change-me

# --- AI orchestrator ---
# Port 5050 (not 5000): macOS's AirPlay Receiver binds :5000 by default
# since macOS 12, which blocks `pnpm dev` for contributors on Macs.
AI_ORCHESTRATOR_URL=http://localhost:5050
NEXT_PUBLIC_AI_ORCHESTRATOR_URL=http://localhost:5050

# --- Sandbox provisioner ---
# Prefer 127.0.0.1 over localhost on macOS: Node may resolve localhost to IPv6
# (::1) while uvicorn binds IPv4-only, causing "fetch failed" from Next.js API routes.
#
# Port 6500 (not 6000): port 6000 is on the WHATWG Fetch "bad ports" blocklist
# (historical X11 port), so Node's built-in fetch (undici) refuses to connect
# and throws `TypeError: fetch failed` with cause "bad port".
SANDBOX_PROVISIONER_URL=http://127.0.0.1:6500

# Docker image used inside each per-interview sandbox container.
# Default points at the private GHCR image used in CI/prod. For local dev,
# build the bundled Dockerfile and override this to the local tag, otherwise
# `POST /sandboxes` will fail with "denied" trying to pull from ghcr:
#   docker build -f apps/sandbox-provisioner/sandbox-base.Dockerfile \
#     -t leucent/sandbox-base:local apps/sandbox-provisioner
SANDBOX_IMAGE=leucent/sandbox-base:local

# --- S3 / object storage for replay logs ---
# In dev we use the MinIO container in docker-compose.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=leucent-replays
S3_ACCESS_KEY_ID=leucent
S3_SECRET_ACCESS_KEY=leucentminio

# --- Neon (only required when running against real Neon, not local dev) ---
NEON_API_KEY=
NEON_PROJECT_ID=
NEON_PARENT_BRANCH_ID=

# --- LLM providers (LiteLLM picks these up) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LITELLM_DEFAULT_MODEL=gpt-4o-mini

# --- Misc ---
NODE_ENV=development
