# =====================================================================
# Leucent root environment template.
# Copy to .env (or .env.local for the Next.js app) and fill in values.
# Per-app .env.local files extend these for local development.
# =====================================================================

# --- Postgres (Neon in prod, local pgvector container in dev) ---
DATABASE_URL=postgres://leucent:leucent@localhost:5432/leucent

# --- Better Auth ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-32-byte-secret
BETTER_AUTH_URL=http://localhost:3000

# --- Realtime server ---
REALTIME_SERVER_URL=http://localhost:4000
# Browser-facing (ws://) URL for Yjs + telemetry.
NEXT_PUBLIC_REALTIME_WS_URL=ws://localhost:4000
# Shared secret used by web/AI/sandbox to call realtime /internal/* routes.
REALTIME_INTERNAL_TOKEN=local-dev-internal-token-change-me
# JWT signing secret (must match between web app and realtime server).
REALTIME_JWT_SECRET=local-dev-jwt-secret-change-me

# --- AI orchestrator ---
AI_ORCHESTRATOR_URL=http://localhost:5000
NEXT_PUBLIC_AI_ORCHESTRATOR_URL=http://localhost:5000

# --- Sandbox provisioner ---
SANDBOX_PROVISIONER_URL=http://localhost:6000

# --- S3 / object storage for replay logs ---
# In dev we use the MinIO container in docker-compose.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=leucent-replays
S3_ACCESS_KEY_ID=leucent
S3_SECRET_ACCESS_KEY=leucentminio

# --- Neon (only required when running against real Neon, not local dev) ---
NEON_API_KEY=
NEON_PROJECT_ID=
NEON_PARENT_BRANCH_ID=

# --- LLM providers (LiteLLM picks these up) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LITELLM_DEFAULT_MODEL=gpt-4o-mini

# --- Misc ---
NODE_ENV=development
